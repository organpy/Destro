{
    "name": "destro",
    "productName": "Destro",
    "private": true,
    "version": "1.2.0",
    "main": "main.js",
    "scripts": {
        "dev": "vite",
        "dev:browser": "vite --clearScreen false",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "vite",
        "dist:win": "vite build && electron-builder --win",
        "dist:linux": "vite build && electron-builder --linux",
        "dist:all": "vite build && electron-builder --win --linux"
    },
    "build": {
        "appId": "com.aymenzito.destro",
        "productName": "Destro",
        "copyright": "Copyright © 2026 Aymenzito",
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "main.js",
            "preload.js",
            "assets/**/*",
            "package.json"
        ],
        "directories": {
            "output": "release"
        },
        "win": {
            "target": [
                { "target": "nsis", "arch": ["x64"] },
                { "target": "portable", "arch": ["x64"] }
            ],
            "icon": "assets/Destro.ico",
            "signingHashAlgorithms": null,
            "signAndEditExecutable": false
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Destro"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "rpm",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/Destro.ico",
            "category": "Audio",
            "synopsis": "Synchronized co-listening platform",
            "description": "High-fidelity music listening platform for synchronized sessions.",
            "maintainer": "Aymenzito"
        }
    },
    "dependencies": {
        "discord-rpc": "^4.0.1",
        "electron-store": "^8.1.0",
        "firebase": "^12.10.0",
        "framer-motion": "^11.0.8",
        "lucide-react": "^0.344.0",
        "peerjs": "^1.5.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.64",
        "@types/react-dom": "^18.2.21",
        "@vitejs/plugin-react-swc": "^3.5.0",
        "electron": "^29.1.1",
        "electron-builder": "^24.13.3",
        "vite": "^5.1.6",
        "vite-plugin-electron": "^0.28.2",
        "vite-plugin-electron-renderer": "^0.14.5"
    }
}
